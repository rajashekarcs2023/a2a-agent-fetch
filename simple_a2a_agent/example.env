# Copy to .env in this directory (simple_a2a_agent/) or export manually.
GOOGLE_API_KEY=your_api_key_here

# Passed to LiteLLM — use gemini/<model> for Google AI Studio + GOOGLE_API_KEY.
# (Do not use a bare model id like gemini-2.5-flash; LiteLLM may pick Vertex and require ADC.)
LITELLM_MODEL=gemini/gemini-2.5-flash

# Optional: use Vertex instead of API key
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project
# GOOGLE_CLOUD_LOCATION=us-central1

# Public URL for the agent card (required when exposing via ngrok or another tunnel)
# Example: APP_URL=https://abcd-12-34-56-78.ngrok-free.app
# TRUST_PROXY=1
#
# Run server (port must match ngrok):  python -m simple_a2a_agent --port 10000
# In another terminal:                 ngrok http 10000

# Test client (examples/test_a2a_client.py): base URL of this agent
# A2A_AGENT_URL=http://127.0.0.1:10000
# TEST_MESSAGE=What is the weather in Seattle, WA?

# Agentverse (Launch your agent): paste the full init URL from the UI into .env — do not commit it.
# AGENTVERSE_SDK_INIT_URL=https://USER:TOKEN@agentverse.ai/your-agent-path
